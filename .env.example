# SmartKB environment example

DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
ZHIPUAI_API_KEY=your_zhipu_key
DASHSCOPE_API_KEY=your_dashscope_key
GEMINI_API_KEY=your_gemini_key
DB_URL=your_postgresql_connection_string
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
COLLECTION_NAME=my_rag_collection
VECTOR_DIM=1024
CHUNK_SIZE=500
CHUNK_OVERLAP=50
SPLITTER_STRATEGY=semantic
SPLITTER_SEMANTIC_EMBEDDINGS=true
SPLITTER_SEMANTIC_THRESHOLD=0.55
RERANK_MODE=lexical
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_CONTEXT_MAX_CHARS=4000
RAG_CONTEXT_MAX_TOKENS=1400
MAX_UPLOAD_BYTES=10485760
REDIS_URL=redis://127.0.0.1:6379/0
CACHE_BACKEND=auto
QUERY_CACHE_ENABLED=true
QUERY_CACHE_TTL_SECONDS=600
